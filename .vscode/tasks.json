{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "學校要求編譯指令 (C++23)",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++23",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}